@startuml Grupp32

'comment
'<|-- inheritence
'*-- composition
'o-- aggregation
'--> uses(or dependency)

Title TRASHMAN(Terrific and Right Application for Swedish Humans Managing Avfall Now)

class Main{
    +run()
}

class MainMenu{
    'Motverka DIP
    -OutputFormatter OutputFormatter
    -InputValidator inputValidator
    -ProductManager productManager
    -MaterialManager materialManager
    -handleInput(String choice)
    -printMenu()
    +run()
}

class ProductMenu{
    +run()
}

class MaterialMenu{
    +run()
}

class ReportMenu{
    -ProductManager productManager
    -MaterialManager materialManager
    -RecyclingGuidence recyclingGuidence
}

interface MenuInterface{
    +run()
    -printMenu()
}

class MaterialManager{

}

class Material{
    -String name
    -int impactValue
    -String instruction
    -enum RecyclingCategory
}

class Product{
    -String name
    -Material[] materials
    -int lifespan
    -String category
    '+Product()
}

interface ImpactCalculationStrategy{
    +calculateImpact(Product product)
}

class RecyclingGuidence{
    +isProductRecyclable(Product product)
}


class SimpleSumStrategy{
    +calculateImpact(Product product)
}

class WeightedByLifespanStrategy{
    +calculateImpact(Product product)
}

class ProductManager{
    -Product[] products
    +createProduct()
    +listProducts()
    +getDetails()
    +calculateImpact(Product product)
}

class OutputFormatter{

}

class InputValidator{
    +ValidateInt(String string)
}

Main "1" o-- "1" MainMenu
MenuInterface <-- MainMenu
MainMenu *-- OutputFormatter
MainMenu *-- InputValidator
MainMenu *-- MaterialMenu
MainMenu *-- ProductMenu
ProductMenu *-- ReportMenu
MaterialMenu *-- ReportMenu
MenuInterface <-- MaterialMenu
MenuInterface <-- ProductMenu
ReportMenu "1" o-- "1" ProductManager
ReportMenu "1" o-- "1" MaterialManager
ReportMenu o-- RecyclingGuidence
ProductManager "1" --> "many" Product
ProductManager --> ImpactCalculationStrategy
Product "1" *-- "many" Material

ImpactCalculationStrategy <-- WeightedByLifespanStrategy
ImpactCalculationStrategy <-- SimpleSumStrategy
